  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+lipsync",
      "url": "/handle-protocol?url=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/process",
      "accept": {
        "audio/mp3": [".mp3"],
        "audio/wav": [".wav"],
        "audio/m4a": [".m4a"],
        "audio/ogg": [".ogg"],
        "video/mp4": [".mp4"],
        "video/quicktime": [".mov"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", "video/*"]
        }
      ]
    }
  }
}