{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "npm start",
      "startServerReadyPattern": "ready on",
      "url": [
        "http://localhost:3000",
        "http://localhost:3000/profiles",
        "http://localhost:3000/process",
        "http://localhost:3000/cinematography",
        "http://localhost:3000/visualizations"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --headless",
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 0,
          "uploadThroughputKbps": 0
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.9}],
        "categories:accessibility": ["error", {"minScore": 0.9}],
        "categories:best-practices": ["warn", {"minScore": 0.9}],
        "categories:seo": ["warn", {"minScore": 0.8}],
        "categories:pwa": ["warn", {"minScore": 0.8}],
        
        "first-contentful-paint": ["warn", {"maxNumericValue": 2000}],
        "largest-contentful-paint": ["warn", {"maxNumericValue": 2500}],
        "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.1}],
        "total-blocking-time": ["warn", {"maxNumericValue": 300}],
        "speed-index": ["warn", {"maxNumericValue": 3400}],
        
        "uses-webp-images": "off",
        "uses-text-compression": "warn",
        "uses-rel-preconnect": "warn",
        "efficient-animated-content": "off",
        
        "tap-targets": "warn",
        "meta-viewport": "error",
        "html-has-lang": "error",
        "aria-labels": "warn",
        
        "bootup-time": ["warn", {"maxNumericValue": 3000}],
        "mainthread-work-breakdown": ["warn", {"maxNumericValue": 1000}],
        "font-display": "warn",
        
        "pwa-cross-browser": "off",
        "pwa-installable": "warn",
        "pwa-offline": "warn",
        "pwa-page-transitions": "warn",
        
        "is-crawlable": "warn",
        "robots-txt": "warn",
        "canonical": "warn",
        "hreflang": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}